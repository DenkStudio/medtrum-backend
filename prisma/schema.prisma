generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  superadmin
  admin
  patient
  educator
  super_educator
  logistica
}

enum OrganizationName {
  Mec
  Intecmed
}

enum ClaimStatus {
  pending
  approved
  rejected
  annulled
  reimbursed
  received
}


enum HardwareStatus {
  active
  maintenance
  retired
  inactive
  replaced
}


enum DeliveryType {
  supply_delivery
  claim_reimbursement
}

enum SupplyType {
  SENSOR
  PARCHE_200U
  PARCHE_300U
  TRANSMISOR
  BASE_BOMBA_200U
  BASE_BOMBA_300U
  CABLE_TRANSMISOR
  PDM
}

enum ClaimErrorCode {
  // Sensor
  SENSOR_FALLA
  SENSOR_FALTA_ADHESIVO
  SENSOR_DIFERENCIA_CAPILAR
  SENSOR_PERDIDO
  SENSOR_DESCONOCIDO
  SENSOR_SANGRADO_COLOCACION
  SENSOR_OTROS

  // Parche
  PARCHE_FALTA_ADHESIVO
  PARCHE_ERROR
  PARCHE_OBSTRUCCION
  PARCHE_BATERIA_AGOTADA
  PARCHE_ERROR_CEBADO
  PARCHE_DESACTIVADO
  PARCHE_OTROS

  // Transmisor
  TRANSMISOR_CONECTORES_OXIDADOS
  TRANSMISOR_LUZ_VERDE_NO_PARPADEA
  TRANSMISOR_PROBLEMAS_BATERIA
  TRANSMISOR_ROTURA
  TRANSMISOR_OTROS

  // Base Bomba
  BASE_BOMBA_CONECTORES_OXIDADOS
  BASE_BOMBA_NO_ENCASTRA
  BASE_BOMBA_NO_HACE_PITIDOS
  BASE_BOMBA_ROTURA
  BASE_BOMBA_OTROS

  // Cable Transmisor
  CABLE_NO_CARGA
  CABLE_PIN_DOBLADO
  CABLE_OTROS

  // PDM
  PDM_NO_CARGA_NO_ENCIENDE
  PDM_SE_APAGA_SOLO
  PDM_NO_CARGA
  PDM_ROTURA
  PDM_OTROS
}

// ==================== MAIN MODELS ====================

model Organization {
  id        String           @id @default(uuid())
  name      OrganizationName
  code      String           @unique
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  users       User[]
  educators   Educator[]
  localidades Localidad[]

  hardware       HardwareSupply[]
  deliveries     Delivery[]
  calendarEvents CalendarEvent[]

  @@map("organizations")
}

model Healthcare {
  id        String   @id @default(uuid())
  tradeName String   @map("trade_name")
  legalName String   @map("legal_name")
  cuit      String?  @unique @map("cuit")
  rnos      String?  @unique @map("rnos")
  sigla     String?  @map("sigla")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("healthcares")
}

model Doctor {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patients User[]

  @@map("doctors")
}

model Educator {
  id             String   @id @default(uuid())
  name           String
  province       String
  telephone      String?
  organizationId String?  @map("organization_id")
  userId         String?  @unique @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation("EducatorUser", fields: [userId], references: [id])
  patients     User[]        @relation("PatientEducator")

  @@map("educators")
}

model User {
  id                String    @id @default(uuid())
  supabaseId        String?   @unique @map("supabase_id")
  email             String    @unique
  role              UserRole  @default(patient)
  organizationId    String?   @map("organization_id")
  healthcareId      String?   @map("healthcare_id")
  fullName          String?   @map("full_name")
  phoneNumber       String?   @map("phone_number")
  dni               String?
  address           String?
  birthDate         DateTime? @map("birth_date")
  province          String?
  localidadId       String?   @map("localidad_id")
  familyContactName         String?   @map("family_contact_name")
  familyContactEmail        String?   @map("family_contact_email")
  familyContactPhone        String?   @map("family_contact_phone")
  familyContactRelationship String?   @map("family_contact_relationship")
  doctorId          String?   @map("doctor_id")
  educatorId        String?   @map("educator_id")
  balanceDaysSensor Int       @default(0) @map("balance_days_sensor")
  balanceDaysParche Int       @default(0) @map("balance_days_parche")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  healthcare   Healthcare?   @relation(fields: [healthcareId], references: [id])
  doctor       Doctor?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  educator     Educator?     @relation("PatientEducator", fields: [educatorId], references: [id], onDelete: SetNull)
  educatorProfile Educator?  @relation("EducatorUser")
  localidad    Localidad?    @relation(fields: [localidadId], references: [id], onDelete: SetNull)

  claims                      Claim[]              @relation("UserClaims")
  claimsResolved              Claim[]              @relation("ClaimResolvedBy")
  claimsReimbursed            Claim[]              @relation("ClaimReimbursedBy")
  deliveries                  Delivery[]                   @relation("UserDeliveries")
  deliveriesAssigned          Delivery[]                   @relation("DeliveryAssignedBy")

  hardwareSupplies            HardwareSupply[]

  medicalEntries              MedicalEntry[]               @relation("PatientMedicalEntries")
  medicalEntriesCreated       MedicalEntry[]               @relation("MedicalEntryCreatedBy")
  calendarEventsCreated       CalendarEvent[]              @relation("CalendarEventCreatedBy")

  @@index([organizationId])
  @@index([role])
  @@index([healthcareId])
  @@index([doctorId])
  @@index([educatorId])
  @@map("users")
}

model Claim {
  id                      String      @id @default(uuid())
  userId                  String      @map("user_id")
  supply                  SupplyType?
  daysClaimed             Int?        @map("days_claimed")
  status                  ClaimStatus @default(pending)
  description             String?
  lotNumber               String?     @map("lot_number")
  serialNumber            String?     @map("serial_number")
  claimCategory           SupplyType?  @map("claim_category")
  errorCode               ClaimErrorCode? @map("error_code")
  photoUrl                String?     @map("photo_url")
  failureDate             DateTime?   @map("failure_date")
  colocationDate          DateTime?   @map("colocation_date")
  observations            Json?      @default("[]")
  returnedLots            Json?       @map("returned_lots")
  resolutionMessage       String?     @map("resolution_message")
  balanceAfterResolution  Int?        @map("balance_after_resolution")
  resolvedById            String?     @map("resolved_by_id")
  resolvedAt              DateTime?   @map("resolved_at")
  reimbursedById          String?     @map("reimbursed_by_id")
  reimbursedAt            DateTime?   @map("reimbursed_at")
  reimbursementPhotoUrl   String?     @map("reimbursement_photo_url")
  trackingLink            String?     @map("tracking_link")
  shippingDate            DateTime?   @map("shipping_date")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  user         User              @relation("UserClaims", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy   User?             @relation("ClaimResolvedBy", fields: [resolvedById], references: [id])
  reimbursedBy User?             @relation("ClaimReimbursedBy", fields: [reimbursedById], references: [id])
  deliveries   Delivery[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("claims")
}


model HardwareSupply {
  id             String         @id @default(uuid())
  type           SupplyType
  serialNumber   String?        @map("serial_number")
  lotNumber      String?        @map("lot_number")
  status         HardwareStatus @default(active)
  userId         String?        @map("user_id")
  organizationId String?        @map("organization_id")
  saleDate       DateTime?      @map("sale_date")
  assignedDate   DateTime?      @map("assigned_date")
  placementDate  DateTime?      @map("placement_date")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  linkedHardwareId String?        @map("linked_hardware_id")

  organization   Organization?    @relation(fields: [organizationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  linkedHardware HardwareSupply?  @relation("LinkedHardware", fields: [linkedHardwareId], references: [id], onDelete: SetNull)
  linkedFrom     HardwareSupply[] @relation("LinkedHardware")

  @@unique([serialNumber, type])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@map("hardware_supplies")
}

// ==================== EMBEDDED ARRAYS -> SEPARATE TABLES ====================

model Delivery {
  id              String       @id @default(uuid())
  type            DeliveryType
  userId          String       @map("user_id")
  organizationId  String?      @map("organization_id")

  claimId         String?      @map("claim_id")
  quantity        Int          @default(0)
  daysReimbursed  Int?         @map("days_reimbursed")
  itemName        SupplyType?  @map("item_name")
  lotNumber       Json?        @map("lot_number")
  trackingNumber  String?      @map("tracking_number")
  courierName     String?      @map("courier_name")
  contactName     String?      @map("contact_name")
  contactPhone    String?      @map("contact_phone")
  contactEmail    String?      @map("contact_email")
  date            DateTime     @default(now())
  assignedById    String?      @map("assigned_by")
  observations       Json?       @default("[]")
  photoUrl           String?      @map("photo_url")
  internalPhotoUrls  String[]     @default([]) @map("internal_photo_urls")
  externalPhotoUrls  String[]     @default([]) @map("external_photo_urls")
  receivedByPatient  Boolean      @default(false) @map("received_by_patient")
  receivedAt         DateTime?    @map("received_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user         User              @relation("UserDeliveries", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization?     @relation(fields: [organizationId], references: [id])

  claim        Claim?            @relation(fields: [claimId], references: [id], onDelete: SetNull)
  assignedBy   User?             @relation("DeliveryAssignedBy", fields: [assignedById], references: [id])

  @@index([userId])
  @@index([claimId])
  @@index([organizationId])
  @@map("deliveries")
}



enum CalendarEventColor {
  sky
  indigo
  amber
  emerald
  rose
}

model CalendarEvent {
  id             String             @id @default(uuid())
  title          String
  description    String?
  startDate      DateTime           @map("start_date")
  endDate        DateTime?          @map("end_date")
  color          CalendarEventColor @default(sky)
  category       String?
  organizationId String?            @map("organization_id")
  createdById    String             @map("created_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  createdBy    User          @relation("CalendarEventCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([startDate])
  @@map("calendar_events")
}

model MedicalEntry {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  createdById String   @map("created_by_id")
  visitDate   DateTime @map("visit_date")
  notes       String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient   User @relation("PatientMedicalEntries", fields: [patientId], references: [id], onDelete: Cascade)
  createdBy User @relation("MedicalEntryCreatedBy", fields: [createdById], references: [id])

  @@index([patientId])
  @@map("medical_entries")
}

model Localidad {
  id             String   @id @default(uuid())
  name           String
  province       String
  organizationId String?  @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  users        User[]

  @@unique([name, province, organizationId])
  @@map("localidades")
}
